<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.testingsystem.client.controller.TestPassingController"
            prefHeight="600.0" prefWidth="800.0" styleClass="main-pane">

    <children>
        <BorderPane>
            <!-- Top Bar with Timer -->
            <top>
                <HBox alignment="CENTER" spacing="20.0" styleClass="top-bar">
                    <padding>
                        <Insets top="10.0" right="20.0" bottom="10.0" left="20.0"/>
                    </padding>
                    
                    <Label fx:id="testTitleLabel" text="Test Title" styleClass="section-title"/>
                    
                    <Region HBox.hgrow="ALWAYS"/>
                    
                    <Label text="Time Remaining:"/>
                    <Label fx:id="timerLabel" text="00:00" styleClass="timer-label">
                        <font>
                            <Font name="System Bold" size="18.0"/>
                        </font>
                    </Label>
                    
                    <Region HBox.hgrow="ALWAYS"/>
                    
                    <Button text="Submit Test" onAction="#handleSubmitTest" styleClass="submit-button"/>
                </HBox>
            </top>
            
            <!-- Questions Area -->
            <center>
                <ScrollPane fx:id="questionsScrollPane" fitToWidth="true">
                    <VBox fx:id="questionsContainer" spacing="20.0">
                        <padding>
                            <Insets top="20.0" right="30.0" bottom="20.0" left="30.0"/>
                        </padding>
                    </VBox>
                </ScrollPane>
            </center>
            
            <!-- Bottom Navigation -->
            <bottom>
                <HBox alignment="CENTER" spacing="20.0">
                    <padding>
                        <Insets top="10.0" right="20.0" bottom="10.0" left="20.0"/>
                    </padding>
                    
                    <Button fx:id="prevButton" text="Previous" onAction="#handlePrevious"/>
                    <Label fx:id="questionNumberLabel" text="Question 1 of 10"/>
                    <Button fx:id="nextButton" text="Next" onAction="#handleNext"/>
                </HBox>
            </bottom>
        </BorderPane>
    </children>
</AnchorPane>
